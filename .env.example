# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host/database

# App
SECRET_KEY=your_secret_key_here_32_chars_min
ENVIRONMENT=development

# Slack (optional)
SLACK_WEBHOOK_URL=
